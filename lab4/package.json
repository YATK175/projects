{
  "name": "lab-4-fastify-book-catalog",
  "version": "1.0.0",
  "description": "Laboratory work 4: Fastify Book Catalog API, variant 3",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "imports": {
    "#constants/*": "./src/constants/*.js",
    "#controllers/*": "./src/controllers/*.js",
    "#plugins/*": "./src/plugins/*.js",
    "#repositories/*": "./src/repositories/*.js",
    "#routes/*": "./src/routes/*.js",
    "#schemas/*": "./src/schemas/*.js",
    "#services/*": "./src/services/*.js",
    "#utils/*": "./src/utils/*.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "predev": "npm run check",
    "dev": "node --watch src/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "npm run lint && npm run format:check"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/env": "^5.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/sensible": "^6.0.3",
    "fastify": "^5.4.0",
    "fastify-plugin": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "eslint": "^9.29.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3"
  }
}
