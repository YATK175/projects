{
  "name": "lab-9-jwt",
  "version": "1.0.0",
  "description": "Laboratory work 9, variant 3 Books, Lab_9_JWT fixed local JSON storage without MySQL/Redis setup errors",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "imports": {
    "#constants/*": "./src/constants/*.js",
    "#controllers/*": "./src/controllers/*.js",
    "#migrations/*": "./src/migrations/*.js",
    "#models/*": "./src/models/*.js",
    "#plugins/*": "./src/plugins/*.js",
    "#repositories/*": "./src/repositories/*.js",
    "#routes/*": "./src/routes/*.js",
    "#schemas/*": "./src/schemas/*.js",
    "#services/*": "./src/services/*.js",
    "#utils/*": "./src/utils/*.js",
    "#events/*": "./src/events/*.js",
    "#transforms/*": "./src/transforms/*.js",
    "#db/*": "./src/db/*.js",
    "#db-models/*": "./src/db/models/*.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "predev": "npm run check",
    "dev": "node --watch src/server.js",
    "seed": "node src/scripts/seed.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "npm run lint && npm run format:check",
    "external": "json-server db.json --port 3001",
    "seed:force": "node src/scripts/seed.js --force",
    "db:generate": "node src/scripts/migrate.js",
    "db:migrate": "node src/scripts/migrate.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^11.0.0",
    "@fastify/env": "^5.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/redis": "^7.0.2",
    "@fastify/sensible": "^6.0.3",
    "@fastify/static": "^8.2.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@fastify/websocket": "^11.0.2",
    "argon2": "^0.43.0",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.5.2",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.4.0",
    "fastify-plugin": "^5.0.1",
    "mysql2": "^3.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "eslint": "^9.29.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "json-server": "^1.0.0-beta.3",
    "drizzle-kit": "^0.31.1"
  }
}
